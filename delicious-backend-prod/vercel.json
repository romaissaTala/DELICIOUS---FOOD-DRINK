{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/products.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/categories.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/cart.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/orders.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/payment/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/products",
      "dest": "/api/products.js"
    },
    {
      "src": "/api/categories",
      "dest": "/api/categories.js"
    },
    {
      "src": "/api/cart(.*)",
      "dest": "/api/cart.js"
    },
    {
      "src": "/api/orders(.*)",
      "dest": "/api/orders.js"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth/$1.js"
    },
    {
      "src": "/api/payment/(.*)",
      "dest": "/api/payment/$1.js"
    }
  ]
}